# --- Database ---
# Superuser connection: migrations and seeding only (needs DDL + CREATE ROLE).
DATABASE_URL=postgres://ozimai:ozimai_dev@localhost:5433/ozimai
# Restricted, non-superuser role the running app actually connects as — this
# is the connection RLS policies apply to. Created by the InitSchema
# migration. Never point the app itself at DATABASE_URL above.
APP_DATABASE_URL=postgres://ozimai_app:ozimai_app_dev@localhost:5433/ozimai
# Password the migration assigns to the ozimai_app role when it first creates
# it. REQUIRED (set to something strong) on any deployed environment whose
# Postgres is publicly reachable, e.g. Railway. Keep APP_DATABASE_URL's
# password in sync with this. Defaults to the dev password if unset.
APP_DB_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=dev-only-change-me
MAGIC_LINK_BASE_URL=http://localhost:5173/auth/verify

# --- AI / LLM Router ---
# Leave unset to run entirely on the deterministic MockProvider (fallback).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5

# --- WhatsApp Cloud API (real BSP credentials, optional) ---
# Leave unset to use the DevMockChannelAdapter for local demoing.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Billing (Kaspi Pay, optional) ---
KASPI_MERCHANT_ID=
KASPI_API_KEY=

# --- Backend server ---
PORT=3000
CORS_ORIGIN=http://localhost:5173
